# ==================== 安全配置 ====================
# 必须设置！未设置时将自动生成随机密钥（每次重启后会话失效）
SECRET_KEY=your-secret-key-change-this

# 首次启动初始化的访问密码；未设置则生成随机密码（打印到日志一次）。
# 仅在数据库尚未设置密码时生效，后续可在「设置」页修改，本变量不再覆盖。
# INITIAL_PASSWORD=change-me

# ==================== TMDB 配置 ====================
TMDB_API_KEY=your_tmdb_api_key_here
# TMDB API 基础地址（官方默认）。国内直连超时可改为镜像或自建反代：
#   https://api.themoviedb.org/3       (官方，国内常超时)
#   https://tmdb.movieboxdatalab.com/3 (镜像示例)
# 也可保持官方地址 + 配置 HTTPS_PROXY 代理。
# TMDB_BASE_URL=https://api.themoviedb.org/3

# ==================== Invidious 配置 ====================
# Docker 部署时使用容器名: http://invidious:3000
# 本地开发时使用: http://127.0.0.1:5300
INVIDIOUS_URL=http://invidious:3000

# ==================== 数据库配置 ====================
DATABASE_PATH=./data/tracker.db

# ==================== 同步配置 ====================
# 已完成同步任务在内存中保留的秒数
SYNC_TASK_RETENTION_SECONDS=3600
# 是否为 TMDB 动漫额外使用视频搜索探测最新集数（默认关闭以减少外部请求）
DISCOVER_TMDB_LATEST_EPISODES=false

# ==================== 时区 ====================
TZ=Asia/Shanghai

# ==================== 日志级别 ====================
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ==================== 可选配置 ====================
# PORT=8000
