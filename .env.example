# ==================== \u5b89\u5168\u914d\u7f6e ====================
# \u5fc5\u987b\u8bbe\u7f6e\uff01\u672a\u8bbe\u7f6e\u65f6\u5c06\u81ea\u52a8\u751f\u6210\u968f\u673a\u5bc6\u94a5\uff08\u6bcf\u6b21\u91cd\u542f\u540e\u4f1a\u8bdd\u5931\u6548\uff09
SECRET_KEY=your-secret-key-change-this

# ==================== TMDB \u914d\u7f6e ====================
TMDB_API_KEY=your_tmdb_api_key_here

# ==================== Invidious \u914d\u7f6e ====================
# Docker \u90e8\u7f72\u65f6\u4f7f\u7528 host.docker.internal \u8bbf\u95ee\u5bbf\u4e3b\u673a\u4e0a\u7684 Invidious
# \u672c\u5730\u5f00\u53d1\u65f6\u4f7f\u7528 http://127.0.0.1:5300
INVIDIOUS_URL=http://host.docker.internal:5300

# ==================== \u6570\u636e\u5e93\u914d\u7f6e ====================
DATABASE_PATH=./data/tracker.db

# ==================== \u65f6\u533a ====================
TZ=Asia/Shanghai

# ==================== \u65e5\u5fd7\u7ea7\u522b ====================
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ==================== \u53ef\u9009\u914d\u7f6e ====================
# PORT=8000
